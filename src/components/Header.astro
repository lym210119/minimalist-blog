---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<header class="py-6">
  <div class="container flex items-center justify-between">
    <a href="/" class="text-title" style="font-size: 1.125rem;">
      {title}
    </a>
    
    <nav class="flex items-center gap-4">
      <a href="/" class="text-small">首页</a>
      <a href="/about" class="text-small">关于</a>
      <ThemeToggle />
    </nav>
  </div>
</header>
